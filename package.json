{
  "name": "the-feed",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "The Feed — audience-coupled generative agents. A live, watchable world of AI characters whose memories are steerable by a real crowd. Qwen Cloud Hackathon (Agent Society track).",
  "license": "MIT",
  "scripts": {
    "sim:day2": "tsx src/sim/day2.ts",
    "sim:town": "tsx src/sim/town.ts",
    "sim:gossip": "tsx src/sim/gossip.ts",
    "sim:audience": "tsx src/sim/audience.ts",
    "sim:ablation": "tsx src/sim/ablation.ts",
    "sim:planning": "tsx src/sim/planning.ts",
    "sim:buffer": "tsx src/sim/buffer.ts",
    "sim:snapshot": "tsx src/sim/snapshot.ts",
    "sim:viewer": "tsx src/sim/viewer.ts",
    "sim:highlights": "tsx src/sim/highlights.ts",
    "sim:life": "tsx src/sim/life.ts",
    "smoke": "tsx src/sim/smoke.ts",
    "smoke:live": "tsx --env-file-if-exists=.env src/sim/smoke.ts",
    "serve": "tsx --env-file-if-exists=.env src/server/server.ts",
    "test": "tsx --test test/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "tsx": "^4.23.0",
    "typescript": "^5.5.0"
  }
}
