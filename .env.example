# Copy to .env (gitignored) to run against real Qwen Cloud instead of the mock.
#   cp .env.example .env   &&   edit in your key   &&   MODEL_BACKEND=dashscope npm run sim:day2

# Which backend the ModelAdapter factory uses: "mock" (default, offline, $0) or "dashscope".
MODEL_BACKEND=dashscope

# Your DashScope / Alibaba Cloud Model Studio API key (looks like sk-...).
DASHSCOPE_API_KEY=sk-your-key-here

# Endpoint. Default (leave unset) is the International region. For the China/Beijing
# region use: https://dashscope.aliyuncs.com/compatible-mode/v1
# DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
